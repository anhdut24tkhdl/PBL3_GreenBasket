@model IEnumerable<PPL3_Banhangonline.Models.Product>
@{
    ViewData["Title"] = "Quản lý kho hàng";
}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-light p-3 rounded shadow-sm">
        <li class="breadcrumb-item">
            <a asp-controller="Seller" asp-action="Index" class="text-decoration-none text-success">
                <i class="bi bi-house-door-fill"></i> Kênh Người Bán
            </a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Quản lý sản phẩm</li>
    </ol>
</nav>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
        <div>
            <h2 class="text-success fw-bold mb-0">📦 QUẢN LÝ KHO HÀNG</h2>
            <small class="text-muted">Cửa hàng: @ViewBag.ShopName</small>
        </div>
        <a asp-action="CreateProduct" class="btn btn-success px-4 py-2 shadow-sm fw-bold">
            <i class="bi bi-plus-circle-fill me-2"></i> THÊM SẢN PHẨM
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.Image" class="rounded-3 shadow-sm me-3"
                                         style="width: 50px; height: 50px; object-fit: cover;"
                                         onerror="this.src='/images/no-image.png'" />
                                    <div>
                                        <div class="fw-bold text-dark">@item.ProductName</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="fw-bold text-success">@item.Price?.ToString("N0")₫</span></td>
                            <td>
                                <span class="badge @(item.Stock < 5 ? "bg-danger" : "bg-light text-dark")">
                                    @item.Stock
                                </span>
                            </td>
                            <td>
                                @if (item.Stock > 0)
                                {
                                    <span class="text-primary small"><i class="bi bi-record-fill"></i> Đang bán</span>
                                }
                                else
                                {
                                    <span class="text-danger small"><i class="bi bi-record-fill"></i> Hết hàng</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="EditProduct" asp-route-id="@item.ProductID"
                                       class="btn btn-outline-primary btn-sm px-3" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="DeleteProduct" asp-route-id="@item.ProductID"
                                       class="btn btn-outline-danger btn-sm px-3"
                                       onclick="return confirm('Xác nhận xóa vĩnh viễn sản phẩm này?')" title="Xóa">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .btn-group .btn:hover {
        transform: scale(1.05);
        z-index: 5;
    }

    tr {
        transition: all 0.2s;
    }

        tr:hover {
            background-color: #f8fff9 !important;
        }
</style>